# 複製此檔為 .env，填入真實值，不要 commit .env
# cp .env.example .env

# ── 資料庫 ──────────────────────────────────────────
POSTGRES_USER=alphalens
POSTGRES_PASSWORD=alphalens
POSTGRES_DB=alphalens
POSTGRES_HOST=localhost   # Docker 內部改為 postgres（由 compose 覆寫）
POSTGRES_PORT=5432
POSTGRES_SSLMODE=disable

# ── 後端 ────────────────────────────────────────────
PORT=8080

# ── 資料來源 ─────────────────────────────────────────
# FinMind API token（https://finmindtrade.com/）
# 免費層：每小時 600 次請求
FINMIND_TOKEN=

# ── LLM（報告產生）──────────────────────────────────
# 本地 Ollama（預設，零成本）
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5:14b

# Claude API（品質升級後切換，設 LLM_PROVIDER=claude）
CLAUDE_API_KEY=

# ── 語音轉文字（播客 Insights）───────────────────────
# Whisper 本地模型：tiny / base / small / medium / large-v3
# 空字串 = 停用（只用 YouTube 字幕或 show notes）
# 建議：中文播客用 small 或 medium（large-v3 最準但需 4GB RAM）
WHISPER_MODEL=
